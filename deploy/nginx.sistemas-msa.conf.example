# Plantilla de referencia (en el server ya vive en /etc/nginx/sites-available/sistemas-msa).
# No aplicar a ciegas: conservar bloques SSL de Certbot al editar.

server {
    server_name sistemas-msa.com www.sistemas-msa.com;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        proxy_pass http://127.0.0.1:8093;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/sistemas-msa.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/sistemas-msa.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = www.sistemas-msa.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = sistemas-msa.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name sistemas-msa.com www.sistemas-msa.com;
    return 404; # managed by Certbot
}
